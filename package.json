{
  "name": "orb-devkit",
  "displayName": "Orb DevKit",
  "description": "Desktop daemon for Orb DevKit mobile app — ENV sync, vault backup, AI blocklist",
  "version": "1.0.0",
  "publisher": "orb-devkit",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orb-container",
          "title": "Orb DevKit",
          "icon": "media/orb-icon.svg"
        }
      ]
    },
    "views": {
      "orb-container": [
        { "id": "orb.main", "name": "Dashboard", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "orb.startDaemon",   "title": "Orb: Start Daemon"         },
      { "command": "orb.stopDaemon",    "title": "Orb: Stop Daemon"          },
      { "command": "orb.showPairing",   "title": "Orb: Show Pairing QR"      },
      { "command": "orb.openDashboard", "title": "Orb: Open Dashboard"       },
      { "command": "orb.resetAll",      "title": "Orb: Reset All Data"       }
    ],
    "configuration": {
      "title": "Orb DevKit",
      "properties": {
        "orb.port": {
          "type": "number",
          "default": 3131,
          "description": "WebSocket port for the Orb daemon"
        },
        "orb.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start daemon when VS Code opens"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --platform=node --external:vscode --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile -- --minify",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0"
  }
}